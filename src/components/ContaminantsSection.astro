---

---

<section id="contaminants-section" class="relative w-full py-32 pointer-events-auto overflow-hidden">
    <!-- Decorative Background Elements -->
    <div
        class="contaminants-glow-1 absolute top-[15%] right-[-10%] w-[35vw] h-[35vw] rounded-full bg-red-500/5 blur-[100px] pointer-events-none opacity-0"
    ></div>
    <div
        class="contaminants-glow-2 absolute bottom-[10%] left-[-10%] w-[30vw] h-[30vw] rounded-full bg-orange-500/5 blur-[100px] pointer-events-none opacity-0"
    ></div>

    <!-- Gradient Accent Lines -->
    <div
        class="contaminants-line absolute top-[12%] left-0 w-[25%] h-[1px] bg-gradient-to-r from-transparent via-red-500/20 to-transparent pointer-events-none opacity-0"
    ></div>
    <div
        class="contaminants-line absolute bottom-[20%] right-0 w-[20%] h-[1px] bg-gradient-to-r from-transparent via-orange-500/20 to-transparent pointer-events-none opacity-0"
    ></div>

    <div class="container mx-auto px-6 md:px-12 relative z-10">
        <!-- Section Header -->
        <div class="text-center mb-16 contaminants-header opacity-0 translate-y-10">
            <div class="w-16 h-[2px] bg-red-500 mx-auto mb-6"></div>
            <h2
                class="text-4xl md:text-5xl font-black uppercase tracking-wide text-white mb-4"
            >
                ¿Por Qué Importa<br />
                <span
                    class="text-transparent bg-clip-text bg-gradient-to-r from-red-400 to-orange-500"
                >
                    Eliminar Contaminantes?
                </span>
            </h2>
            <p class="text-muted text-lg max-w-2xl mx-auto leading-relaxed">
                Los contaminantes del aire son una amenaza invisible. Conoce los
                principales enemigos de tu salud respiratoria y por qué combatirlos
                es urgente.
            </p>
        </div>

        <!-- Main Contaminant Cards -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mb-16">
            <!-- COVs Card -->
            <div
                class="contaminant-card opacity-0 translate-y-10 p-8 rounded-xl bg-white/5 border border-white/10 space-y-6"
            >
                <div class="flex items-center gap-3">
                    <span
                        class="w-10 h-10 rounded-lg bg-orange-500/10 flex items-center justify-center"
                    >
                        <svg
                            class="w-5 h-5 text-orange-400"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <path
                                stroke-linecap="round"
                                stroke-linejoin="round"
                                d="M9.75 3.104v5.714a2.25 2.25 0 01-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 014.5 0m0 0v5.714a2.25 2.25 0 00.659 1.591L19 14.5M14.25 3.104c.251.023.501.05.75.082M19 14.5l-1.47 4.41a1.5 1.5 0 01-1.423 1.04H7.893a1.5 1.5 0 01-1.423-1.04L5 14.5m14 0H5"
                            ></path>
                        </svg>
                    </span>
                    <h3
                        class="text-2xl md:text-3xl font-bold text-white uppercase tracking-wide"
                    >
                        COVs
                    </h3>
                </div>
                <p
                    class="text-orange-400 font-semibold text-sm uppercase tracking-wider"
                >
                    Compuestos Orgánicos Volátiles
                </p>

                <p class="text-muted leading-relaxed">
                    Son sustancias químicas que se evaporan fácilmente a temperatura
                    ambiente. Se encuentran en pinturas, adhesivos, productos de
                    limpieza, combustibles y hasta en muebles nuevos. Son
                    especialmente peligrosos en espacios cerrados.
                </p>

                <div class="space-y-3">
                    <h4
                        class="text-white font-bold text-sm uppercase tracking-wider"
                    >
                        Efectos en la salud
                    </h4>
                    <ul class="space-y-2">
                        <li class="flex items-start gap-3">
                            <span
                                class="w-1.5 h-1.5 rounded-full bg-orange-400 mt-2 shrink-0"
                            ></span>
                            <span class="text-muted text-sm leading-relaxed"
                                >Irritación de ojos, nariz y garganta</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span
                                class="w-1.5 h-1.5 rounded-full bg-orange-400 mt-2 shrink-0"
                            ></span>
                            <span class="text-muted text-sm leading-relaxed"
                                >Dolores de cabeza, náuseas y mareos</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span
                                class="w-1.5 h-1.5 rounded-full bg-orange-400 mt-2 shrink-0"
                            ></span>
                            <span class="text-muted text-sm leading-relaxed"
                                >Daño al hígado, riñones y sistema nervioso central</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span
                                class="w-1.5 h-1.5 rounded-full bg-red-400 mt-2 shrink-0"
                            ></span>
                            <span class="text-muted text-sm leading-relaxed"
                                >Algunos COVs como el benceno y formaldehído son
                                cancerígenos</span
                            >
                        </li>
                    </ul>
                </div>

                <div class="p-4 rounded-lg bg-orange-500/10 border border-orange-500/20">
                    <p class="text-orange-300 text-sm font-medium">
                        La concentración de COVs en interiores es
                        <span class="text-white font-bold">2 a 5 veces mayor</span> que
                        en exteriores — justo donde pasamos el 90% de nuestro tiempo.
                    </p>
                </div>
            </div>

            <!-- PM Card -->
            <div
                class="contaminant-card opacity-0 translate-y-10 p-8 rounded-xl bg-white/5 border border-white/10 space-y-6"
            >
                <div class="flex items-center gap-3">
                    <span
                        class="w-10 h-10 rounded-lg bg-red-500/10 flex items-center justify-center"
                    >
                        <svg
                            class="w-5 h-5 text-red-400"
                            fill="none"
                            viewBox="0 0 24 24"
                            stroke="currentColor"
                            stroke-width="2"
                        >
                            <circle cx="12" cy="12" r="3" />
                            <circle cx="12" cy="12" r="7" stroke-dasharray="2 3" />
                            <circle cx="12" cy="12" r="10" stroke-dasharray="1 4" />
                        </svg>
                    </span>
                    <h3
                        class="text-2xl md:text-3xl font-bold text-white uppercase tracking-wide"
                    >
                        PM
                    </h3>
                </div>
                <p
                    class="text-red-400 font-semibold text-sm uppercase tracking-wider"
                >
                    Material Particulado (PM2.5 y PM10)
                </p>

                <p class="text-muted leading-relaxed">
                    Son partículas microscópicas suspendidas en el aire. Las PM10
                    (≤10μm) incluyen polvo y polen. Las PM2.5 (≤2.5μm) provienen de
                    la combustión y son tan diminutas que penetran profundamente en los
                    pulmones hasta llegar al torrente sanguíneo.
                </p>

                <div class="space-y-3">
                    <h4
                        class="text-white font-bold text-sm uppercase tracking-wider"
                    >
                        Efectos en la salud
                    </h4>
                    <ul class="space-y-2">
                        <li class="flex items-start gap-3">
                            <span
                                class="w-1.5 h-1.5 rounded-full bg-red-400 mt-2 shrink-0"
                            ></span>
                            <span class="text-muted text-sm leading-relaxed"
                                >Asma, bronquitis crónica y enfermedades
                                respiratorias</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span
                                class="w-1.5 h-1.5 rounded-full bg-red-400 mt-2 shrink-0"
                            ></span>
                            <span class="text-muted text-sm leading-relaxed"
                                >Enfermedades cardiovasculares, infartos y
                                arritmias</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span
                                class="w-1.5 h-1.5 rounded-full bg-red-400 mt-2 shrink-0"
                            ></span>
                            <span class="text-muted text-sm leading-relaxed"
                                >Las PM2.5 cruzan la barrera pulmonar al torrente
                                sanguíneo</span
                            >
                        </li>
                        <li class="flex items-start gap-3">
                            <span
                                class="w-1.5 h-1.5 rounded-full bg-red-500 mt-2 shrink-0"
                            ></span>
                            <span class="text-muted text-sm leading-relaxed"
                                >Cáncer de pulmón y muerte prematura por exposición
                                prolongada</span
                            >
                        </li>
                    </ul>
                </div>

                <div class="p-4 rounded-lg bg-red-500/10 border border-red-500/20">
                    <p class="text-red-300 text-sm font-medium">
                        La OMS estima
                        <span class="text-white font-bold"
                            >7 millones de muertes prematuras al año</span
                        > por contaminación del aire a nivel mundial.
                    </p>
                </div>
            </div>
        </div>

        <!-- Impact Stats -->
        <div
            class="contaminants-stats opacity-0 translate-y-10 grid grid-cols-2 md:grid-cols-4 gap-6 p-8 rounded-xl bg-gradient-to-br from-red-500/10 to-orange-500/10 border border-red-500/20"
        >
            <div class="text-center">
                <h4 class="text-3xl md:text-4xl font-black text-white mb-1">
                    7M
                </h4>
                <p class="text-xs text-muted uppercase tracking-widest">
                    Muertes/año por aire contaminado
                </p>
            </div>
            <div class="text-center">
                <h4 class="text-3xl md:text-4xl font-black text-white mb-1">
                    90%
                </h4>
                <p class="text-xs text-muted uppercase tracking-widest">
                    Tiempo en espacios cerrados
                </p>
            </div>
            <div class="text-center">
                <h4 class="text-3xl md:text-4xl font-black text-white mb-1">
                    5x
                </h4>
                <p class="text-xs text-muted uppercase tracking-widest">
                    Más contaminación interior vs exterior
                </p>
            </div>
            <div class="text-center">
                <h4 class="text-3xl md:text-4xl font-black text-white mb-1">
                    91%
                </h4>
                <p class="text-xs text-muted uppercase tracking-widest">
                    Población mundial expuesta
                </p>
            </div>
        </div>
    </div>
</section>

<script>
    import gsap from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    const tl = gsap.timeline({
        scrollTrigger: {
            trigger: "#contaminants-section",
            start: "top 60%",
            end: "bottom 40%",
            toggleActions: "play none none reverse",
        },
    });

    tl.to(".contaminants-header", {
        y: 0,
        opacity: 1,
        duration: 0.8,
        ease: "power3.out",
    });

    tl.to(
        ".contaminant-card",
        {
            y: 0,
            opacity: 1,
            duration: 0.8,
            stagger: 0.2,
            ease: "power3.out",
        },
        "-=0.4",
    );

    tl.to(
        ".contaminants-stats",
        {
            y: 0,
            opacity: 1,
            duration: 0.8,
            ease: "power3.out",
        },
        "-=0.4",
    );

    // Decorative glow animations
    const decorTl = gsap.timeline({
        scrollTrigger: {
            trigger: "#contaminants-section",
            start: "top bottom",
            end: "bottom top",
            scrub: 2,
        },
    });

    decorTl.fromTo(
        ".contaminants-glow-1",
        { opacity: 0, x: "20%" },
        { opacity: 1, x: "-10%", ease: "none" },
    );

    decorTl.fromTo(
        ".contaminants-glow-2",
        { opacity: 0, x: "-20%" },
        { opacity: 1, x: "10%", ease: "none" },
        0,
    );

    decorTl.fromTo(
        ".contaminants-line",
        { opacity: 0, scaleX: 0 },
        { opacity: 1, scaleX: 1, ease: "power1.out", stagger: 0.2 },
        0.1,
    );
</script>
